
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.preprocessing import StandardScaler, MinMaxScaler

plt.style.use('seaborn-v0_8')
sns.set_palette("husl")

column_names = ['age', 'sex', 'cp', 'trestbps', 'chol', 'fbs', 'restecg', 
                'thalach', 'exang', 'oldpeak', 'slope', 'ca', 'thal', 'target']

cleveland = pd.read_csv(r'C:\Users\aruni\OneDrive\Desktop\SC Project\Execute\processed.cleveland.data', 
                       names=column_names, na_values='?')
print(" Cleveland Data Loaded Successfully!")
print("="*50)

print("Dataset Shape:", cleveland.shape)
print("\nMissing Values:")
print(cleveland.isnull().sum())
print("\nData Types:")
print(cleveland.dtypes)

print("\n" + "="*50)
print("DETAILED FEATURE ANALYSIS")
print("="*50)

for col in cleveland.columns:
    print(f"\n--- {col.upper()} ---")
    print(f"Missing: {cleveland[col].isnull().sum()}")
    print(f"Unique values: {sorted(cleveland[col].dropna().unique())}")
    print(f"Value counts:\n{cleveland[col].value_counts(dropna=False).head()}")
fig, axes = plt.subplots(3, 5, figsize=(20, 12))
axes = axes.ravel()

for i, col in enumerate(cleveland.columns[:-1]): 
    if cleveland[col].dtype in ['float64', 'int64']:
        axes[i].hist(cleveland[col].dropna(), bins=20, alpha=0.7, edgecolor='black')
        axes[i].set_title(f'{col} Distribution')
        axes[i].set_xlabel(col)
        axes[i].set_ylabel('Frequency')

for i in range(len(cleveland.columns)-1, len(axes)):
    axes[i].set_visible(False)

plt.tight_layout()
plt.show()

print("=== TARGET VARIABLE ===")
print("Original target distribution:")
print(cleveland['target'].value_counts().sort_index())

cleveland['target_binary'] = (cleveland['target'] > 0).astype(int) #binary rakha hai. 0 no probs, 1-4 danger bhai
print("\nBinary target distribution:")
print(cleveland['target_binary'].value_counts())

plt.figure(figsize=(10, 4))
plt.subplot(1, 2, 1)
cleveland['target'].value_counts().sort_index().plot(kind='bar')
plt.title('Original Target (0-4)')
plt.xlabel('Heart Disease Severity')
plt.ylabel('Count')

plt.subplot(1, 2, 2)
cleveland['target_binary'].value_counts().plot(kind='bar', color=['skyblue', 'salmon'])
plt.title('Binary Target')
plt.xlabel('Heart Disease (0=No, 1=Yes)')
plt.ylabel('Count')
plt.tight_layout()
plt.show()

plt.figure(figsize=(12, 10))
correlation_matrix = cleveland.corr()
sns.heatmap(correlation_matrix, annot=True, cmap='coolwarm', center=0, 
            fmt='.2f', linewidths=0.5)
plt.title('Feature Correlations with Target')
plt.tight_layout()
plt.show()

print("Top correlations with binary target:")
target_correlations = correlation_matrix['target_binary'].abs().sort_values(ascending=False)
print(target_correlations.head(10))

print("=== MISSING VALUE STRATEGY ===")
print(f"Before handling: {cleveland.isnull().sum().sum()} missing values")

cleveland_clean = cleveland.copy()

numerical_features = ['ca'] 
for feature in numerical_features:
    cleveland_clean[feature].fillna(cleveland_clean[feature].median(), inplace=True)

cleveland_clean['thal'].fillna(cleveland_clean['thal'].mode()[0], inplace=True)

print(f"After handling: {cleveland_clean.isnull().sum().sum()} missing values")


print("=== CORRECTING DATA TYPES ===")

categorical_features = ['sex', 'cp', 'fbs', 'restecg', 'exang', 'slope', 'thal', 'target_binary']
for feature in categorical_features:
    cleveland_clean[feature] = cleveland_clean[feature].astype(int)

print("Final data types:")
print(cleveland_clean.dtypes)

cleveland_clean.to_csv('cleveland_cleaned.csv', index=False)
print(" Cleaned Cleveland data saved as 'cleveland_cleaned.csv'")

print("\n" + "="*50)
print("FINAL SUMMARY STATISTICS")
print("="*50)
print(cleveland_clean.describe())
