
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import os

plt.style.use('seaborn-v0_8')
sns.set_palette("husl")

column_names = ['age', 'sex', 'cp', 'trestbps', 'chol', 'fbs', 'restecg', 
                'thalach', 'exang', 'oldpeak', 'slope', 'ca', 'thal', 'target']

hungarian = pd.read_csv(r'C:\Users\aruni\OneDrive\Desktop\SC Project\Execute\processed.hungarian.data', 
                       names=column_names, na_values=['?', -9, -1.0, -1])

print(" Hungarian Data Loaded Successfully!")
print("="*50)
print("Dataset Shape:", hungarian.shape)
print("\nMissing Values:")
print(hungarian.isnull().sum())
print("\nData Types:")
print(hungarian.dtypes)

print("\nMissing Values Percentage:")
missing_percent = (hungarian.isnull().sum() / len(hungarian)) * 100 #missing percentage ke liye
print(missing_percent.round(2))
cleveland_clean = pd.read_csv('cleveland_cleaned.csv')

print("="*50)
print("COMPARISON: CLEVELAND vs HUNGARIAN")
print("="*50)

print(f"\nDataset Sizes:")
print(f"Cleveland: {cleveland_clean.shape}")
print(f"Hungarian: {hungarian.shape}")

print(f"\nMissing Values Comparison:")
print("Feature".ljust(12) + "Cleveland".ljust(12) + "Hungarian".ljust(12))
print("-" * 40)
for col in column_names:
    clev_missing = cleveland_clean[col].isnull().sum() if col in cleveland_clean.columns else 'N/A'
    hung_missing = hungarian[col].isnull().sum()
    print(f"{col.ljust(12)}{str(clev_missing).ljust(12)}{str(hung_missing).ljust(12)}")

print("\n" + "="*50)
print("DETAILED HUNGARIAN FEATURE ANALYSIS")
print("="*50)

for col in hungarian.columns:
    print(f"\n--- {col.upper()} ---")
    print(f"Missing: {hungarian[col].isnull().sum()} ({missing_percent[col]:.1f}%)")
    unique_vals = sorted(hungarian[col].dropna().unique())
    print(f"Unique values: {unique_vals}")
    print(f"Value counts:\n{hungarian[col].value_counts(dropna=False).head(10)}")

fig, axes = plt.subplots(3, 5, figsize=(20, 12))
axes = axes.ravel()

for i, col in enumerate(hungarian.columns[:-1]):  
    if hungarian[col].dtype in ['float64', 'int64'] and hungarian[col].notna().sum() > 0:
        axes[i].hist(hungarian[col].dropna(), bins=20, alpha=0.7, edgecolor='black', color='orange')
        axes[i].set_title(f'Hungarian {col} Distribution')
        axes[i].set_xlabel(col)
        axes[i].set_ylabel('Frequency')

for i in range(len(hungarian.columns)-1, len(axes)):
    axes[i].set_visible(False)

plt.tight_layout()
plt.show()
print("=== TARGET VARIABLE COMPARISON ===")

# Convert Hungarian target to binary (same as Cleveland)
hungarian['target_binary'] = (hungarian['target'] > 0).astype(int)

print("\nCleveland Target Distribution:")
print(cleveland_clean['target_binary'].value_counts())
print("\nHungarian Target Distribution:")
print(hungarian['target_binary'].value_counts())

plt.figure(figsize=(12, 5))

plt.subplot(1, 2, 1)
cleveland_clean['target_binary'].value_counts().plot(kind='bar', color=['skyblue', 'salmon'])
plt.title('Cleveland: Heart Disease\n(0=No, 1=Yes)')
plt.xlabel('Diagnosis')
plt.ylabel('Count')

plt.subplot(1, 2, 2)
hungarian['target_binary'].value_counts().plot(kind='bar', color=['lightgreen', 'gold'])
plt.title('Hungarian: Heart Disease\n(0=No, 1=Yes)')
plt.xlabel('Diagnosis')
plt.ylabel('Count')

plt.tight_layout()
plt.show()
key_features = ['age', 'trestbps', 'chol', 'thalach', 'oldpeak'] #comaprision wale features

fig, axes = plt.subplots(2, 3, figsize=(15, 10))
axes = axes.ravel()

for i, feature in enumerate(key_features):
    # Cleveland data
    axes[i].hist(cleveland_clean[feature].dropna(), bins=20, alpha=0.6, label='Cleveland', color='blue')
    # Hungarian data
    axes[i].hist(hungarian[feature].dropna(), bins=20, alpha=0.6, label='Hungarian', color='red')
    axes[i].set_title(f'{feature} Distribution')
    axes[i].set_xlabel(feature)
    axes[i].set_ylabel('Frequency')
    axes[i].legend()

axes[-1].set_visible(False)
plt.tight_layout()
plt.show()
print("=== DATA QUALITY ASSESSMENT ===")
print("Features with >50% missing values in Hungarian data:")
high_missing = missing_percent[missing_percent > 50]
print(high_missing)

print("\nFeatures that need special attention:")
problem_features = ['ca', 'thal']  
for feature in problem_features:
    if feature in hungarian.columns:
        print(f"\n{feature}:")
        print(f"  Missing: {hungarian[feature].isnull().sum()}")
        print(f"  Unique values: {sorted(hungarian[feature].dropna().unique())}")

print("=== INITIAL CLEANING STRATEGY ===")
hungarian_clean = hungarian.copy()

cleaning_steps = []

cleaning_steps.append("Converted target to binary (0=no disease, 1-4=disease)")

extreme_missing = missing_percent[missing_percent > 80].index.tolist()
if extreme_missing:
    cleaning_steps.append(f"Features with >80% missing: {extreme_missing}")

print("Cleaning steps needed:")
for step in cleaning_steps:
    print(f"• {step}")

hungarian_clean.to_csv('hungarian_initial_clean.csv', index=False)
print("\n Initial cleaned Hungarian data saved as 'hungarian_initial_clean.csv'")

print("="*50)
print("EXPLORATION SUMMARY")
print("="*50)
print(f" Hungarian dataset loaded: {hungarian.shape}")
print(f" Missing values identified and documented")
print(f" Target variable converted to binary")
print(f" Comparison with Cleveland completed")
print(f" Data quality issues identified")
print(f" Initial cleaning performed")
print(f"\n Next steps: Feature engineering to align with Cleveland preprocessing")
