
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.preprocessing import StandardScaler, MinMaxScaler
import joblib  
cleveland = pd.read_csv('cleveland_cleaned.csv')
hungarian = pd.read_csv('hungarian_initial_clean.csv')

print(" Datasets Loaded for Feature Engineering")
print("="*60)
print("FEATURE ENGINEERING STRATEGY")
print("="*60)

print(" PROBLEMATIC FEATURES (High Missing %):")
print(" - ca: 99% missing → DROP FEATURE")
print(" - thal: 90.5% missing → DROP FEATURE") 
print(" - slope: 64.6% missing → DROP FEATURE")

print("\n USABLE FEATURES:")
usable_features = ['age', 'sex', 'cp', 'trestbps', 'chol', 'fbs', 'restecg', 'thalach', 'exang', 'oldpeak', 'target_binary']
print(f" - {', '.join(usable_features)}")

print(f"\nFinal feature count: {len(usable_features)-1} features + target")

print("CREATING CLEANED DATASETS WITH CONSISTENT FEATURES")
print("="*60)

cleveland_final = cleveland[usable_features].copy()
hungarian_final = hungarian[usable_features].copy()

print(f"Cleveland final shape: {cleveland_final.shape}")
print(f"Hungarian final shape: {hungarian_final.shape}")

print("\nMissing values in final Hungarian dataset:")
print(hungarian_final.isnull().sum())
print("HANDLING REMAINING MISSING VALUES")
print("="*60)

imputation_strategy = {}

numerical_to_impute = ['trestbps', 'chol', 'thalach']
for feature in numerical_to_impute:
    if feature in hungarian_final.columns:
        median_val = hungarian_final[feature].median()
        hungarian_final[feature].fillna(median_val, inplace=True)
        imputation_strategy[feature] = f'median ({median_val})'
        print(f" {feature}: filled with median = {median_val}")

categorical_to_impute = ['fbs', 'restecg', 'exang']
for feature in categorical_to_impute:
    if feature in hungarian_final.columns:
        mode_val = hungarian_final[feature].mode()[0]
        hungarian_final[feature].fillna(mode_val, inplace=True)
        imputation_strategy[feature] = f'mode ({mode_val})'
        print(f" {feature}: filled with mode = {mode_val}")

print(f"\n Final missing values: {hungarian_final.isnull().sum().sum()}")
print("VERIFYING DATA TYPE CONSISTENCY")
print("="*60)

print("Cleveland data types:")
print(cleveland_final.dtypes)
print("\nHungarian data types:")
print(hungarian_final.dtypes)

categorical_features = ['sex', 'cp', 'fbs', 'restecg', 'exang', 'target_binary']
for feature in categorical_features:
    if feature in hungarian_final.columns:
        hungarian_final[feature] = hungarian_final[feature].astype(int)
        print(f" {feature}: converted to int")

print("\n Data types are now consistent!")
print("FINAL FEATURE DISTRIBUTION COMPARISON")
print("="*60)        
#yeh sab sirf visualisation ke liye hai, taaki hum dekh sakein ki distributions match karte hain ya nahi, not feature enggggggg
print("\nKey Statistics Comparison:")
comparison_stats = pd.DataFrame({
    'Cleveland_Mean': cleveland_final.mean(),
    'Hungarian_Mean': hungarian_final.mean(),
    'Cleveland_Std': cleveland_final.std(),
    'Hungarian_Std': hungarian_final.std()
})
print(comparison_stats.round(2))

fig, axes = plt.subplots(3, 3, figsize=(15, 12))
key_features = ['age', 'trestbps', 'chol', 'thalach', 'oldpeak', 'cp']

for i, feature in enumerate(key_features):
    if i < 6:  #sirf pehele ke 6 features
        row, col = i // 3, i % 3
 
        axes[row, col].hist(cleveland_final[feature], bins=20, alpha=0.6, label='Cleveland', color='blue', density=True)

        axes[row, col].hist(hungarian_final[feature], bins=20, alpha=0.6, label='Hungarian', color='red', density=True)
        axes[row, col].set_title(f'{feature} Distribution')
        axes[row, col].set_xlabel(feature)
        axes[row, col].set_ylabel('Density')
        axes[row, col].legend()

for i in range(len(key_features), 9):
    row, col = i // 3, i % 3
    axes[row, col].set_visible(False)

plt.tight_layout()

print("APPLYING CONSISTENT PREPROCESSING")
print("="*60)

numerical_features = ['age', 'trestbps', 'chol', 'thalach', 'oldpeak']   #yeh hai numeric scaling ke liye

scaler = MinMaxScaler()
cleveland_scaled = cleveland_final.copy()
cleveland_scaled[numerical_features] = scaler.fit_transform(cleveland_scaled[numerical_features])

hungarian_scaled = hungarian_final.copy()
hungarian_scaled[numerical_features] = scaler.transform(hungarian_scaled[numerical_features])

print(" Applied consistent MinMax scaling")
print(f"Scaled feature ranges - Cleveland: {cleveland_scaled[numerical_features].min().min():.2f} to {cleveland_scaled[numerical_features].max().max():.2f}")
print(f"Scaled feature ranges - Hungarian: {hungarian_scaled[numerical_features].min().min():.2f} to {hungarian_scaled[numerical_features].max().max():.2f}")

joblib.dump(scaler, 'minmax_scaler.pkl')
print(" Scaler saved as 'minmax_scaler.pkl'")
plt.show()

print("FINAL VALIDATION CHECK")
print("="*60)

print(" SHAPES:")
print(f"Cleveland (train): {cleveland_scaled.shape}")
print(f"Hungarian (test): {hungarian_scaled.shape}")

print("\n FEATURES:")
print(f"Features: {list(cleveland_scaled.columns)}")

print("\n DATA TYPES:")
print("Cleveland:", cleveland_scaled.dtypes.unique())
print("Hungarian:", hungarian_scaled.dtypes.unique())

print("\n MISSING VALUES:")
print("Cleveland:", cleveland_scaled.isnull().sum().sum())
print("Hungarian:", hungarian_scaled.isnull().sum().sum())

print("\n TARGET DISTRIBUTION:")
print("Cleveland:", cleveland_scaled['target_binary'].value_counts().to_dict())
print("Hungarian:", hungarian_scaled['target_binary'].value_counts().to_dict())

print("SAVING FINAL DATASETS")
print("="*60)

cleveland_scaled.to_csv('cleveland_final_ready.csv', index=False)
hungarian_scaled.to_csv('hungarian_final_ready.csv', index=False)

print("Cleveland final (ready for model): 'cleveland_final_ready.csv'")
print("Hungarian final (ready for testing): 'hungarian_final_ready.csv'")

print("\n FEATURE ENGINEERING SUMMARY:")
print("• Removed 3 features with >60% missing values (ca, thal, slope)")
print("• Imputed missing values for remaining features")
print("• Applied consistent data types")
print("• Applied same MinMax scaling as training data")
print("• Final datasets have 10 features + target")
print(f"• Ready to test ANN model on Hungarian data! ")
